# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit real credentials.

# --- Job board APIs ---

# Reed API key. Get one at https://www.reed.co.uk/developers/jobseeker
# Used as HTTP basic auth username; the password is always left empty.
REED_API_KEY=

# JSearch (RapidAPI) key. Subscribe to JSearch at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Free tier = 200 requests/month; JSEARCH_ROLES in config.py is sized to stay within that.
JSEARCH_API_KEY=

# Adzuna API credentials. Register an app at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Minimum salary (GBP) to filter Adzuna results by. Optional, defaults to 60000.
ADZUNA_MIN_SALARY=60000

# --- Claude / Anthropic ---

# Anthropic API key for job scoring, CV/cover-letter generation. Get one at
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Email (Gmail) ---

# Gmail address used to send the daily digest and job applications.
GMAIL_USER=

# Gmail App Password (NOT your regular account password). Generate one at
# https://myaccount.google.com/apppasswords (requires 2FA enabled on the account).
GMAIL_APP_PASSWORD=

# Email address that receives the daily digest. Usually the same as GMAIL_USER.
DIGEST_RECIPIENT=

# Fallback "apply to" email address used when a job description doesn't contain
# a contact email to apply to directly.
DEFAULT_APPLICATION_EMAIL=

# Email address that receives instant alerts when a "dream employer" job is found.
# Usually the same as DIGEST_RECIPIENT.
DREAM_ALERT_RECIPIENT=

# --- Approval webhook (approvals.py) ---

# Port the Flask approval webhook server listens on. Optional, defaults to 5000.
FLASK_PORT=5000

# Base URL where approvals.py is reachable from wherever you read the digest email.
# Must be reachable from your email client, not just localhost, if reading email
# on another device. Optional, defaults to http://localhost:5000.
APPROVAL_BASE_URL=http://localhost:5000

# --- Browser automation (browser_apply.py) ---

# Whether Playwright runs headless (true) or shows a visible browser window (false).
# Optional, defaults to true.
PLAYWRIGHT_HEADLESS=true
